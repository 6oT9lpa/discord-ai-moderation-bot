# Discord Bot Configuration
DISCORD_TOKEN=your_discord_token_here
DISCORD_GUILD_ID=your_guild_id_here
DISCORD_OWNER_ID=your_owner_id_here

# Database Configuration
DATABASE_URL=sqlite:///./bot.db

# Optional Channel/Role IDs
AUTO_ROLE_ID=
LOG_CHANNEL_ID=
WELCOME_CHANNEL_ID=

# Bot Settings
LOG_LEVEL=INFO
COMMAND_PREFIX=!
ACTIVITY_NAME=БОЙЧИК ЦЕЛУЕТ В ЩЕЧКУ, я знаю что он хочет

# Ollama AI Configuration
# Set OLLAMA_ENABLED=true to enable AI features
# Make sure Ollama is running on OLLAMA_BASE_URL before enabling
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
